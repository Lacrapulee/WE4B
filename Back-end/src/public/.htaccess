RewriteEngine On

# 1. Permettre l'accès aux fichiers réels (images, css) si nécessaire
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# 2. Règle pour les URLs avec un ID (ex: api/items/42 ou api/users/12)
RewriteRule ^api/([a-zA-Z0-9_-]+)/([0-9]+)$ api/index.php?action=$1&id=$2 [QSA,L]

# 3. Règle pour les URLs simples (ex: api/catalogue ou api/connexion)
RewriteRule ^api/([a-zA-Z0-9_-]+)$ api/index.php?action=$1 [QSA,L]